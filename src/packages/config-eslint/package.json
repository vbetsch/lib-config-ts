{
    "author": "vbetsch",
    "description": "My ESLint configuration files",
    "engines": {
        "node": "24.14.1"
    },
    "exports": {
        ".": "./src/base.mjs",
        "./base": "./src/base.mjs",
        "./jsx": "./src/jsx.mjs",
        "./naming": "./src/naming.mjs",
        "./prettier": "./src/prettier.mjs",
        "./spellcheck": "./src/spellcheck.mjs",
        "./strict": "./src/strict.mjs"
    },
    "files": [
        "src/"
    ],
    "keywords": [
        "configuration",
        "typescript",
        "eslint"
    ],
    "license": "MIT",
    "name": "@vbetsch/config-eslint",
    "peerDependencies": {
        "@eslint/js": "^9.0.0",
        "eslint": "^9.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-spellcheck": "^0.0.20",
        "typescript-eslint": "^8.56.1"
    },
    "peerDependenciesMeta": {
        "eslint-config-prettier": {
            "optional": true
        },
        "eslint-plugin-import": {
            "optional": true
        },
        "eslint-plugin-jsx-a11y": {
            "optional": true
        },
        "eslint-plugin-prettier": {
            "optional": true
        },
        "eslint-plugin-react": {
            "optional": true
        },
        "eslint-plugin-spellcheck": {
            "optional": true
        }
    },
    "publishConfig": {
